PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dcterms: <http://purl.org/dc/terms/>

SELECT ?metric (COUNT(*) AS ?count)
WHERE {
  {
    ?concept dcterms:references ?reference .
    BIND("dcterms:references triples" AS ?metric)
  }
  UNION
  {
    ?reference dcterms:type "InformativeReference" .
    BIND("informative reference concepts" AS ?metric)
  }
  UNION
  {
    ?reference skos:exactMatch ?iso .
    BIND("skos:exactMatch triples" AS ?metric)
  }
}
GROUP BY ?metric
ORDER BY ?metric

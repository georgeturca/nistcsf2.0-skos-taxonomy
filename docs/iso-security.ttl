        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.27>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.28>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.29>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.3>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.30>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.31>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.32>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.33>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.34>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.35>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.36>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.37>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.4>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.5>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.6>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.7>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.8>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.9> ;
    skos:prefLabel "Organizational Controls"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27001/collection/people> a skos:Collection ;
    skos:member <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.6.1>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.6.2>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.6.3>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.6.4>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.6.5>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.6.6>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.6.7>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.6.8> ;
    skos:prefLabel "People Controls"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27001/collection/physical> a skos:Collection ;
    skos:member <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.1>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.10>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.11>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.12>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.13>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.14>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.2>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.3>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.4>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.5>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.6>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.7>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.8>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.9> ;
    skos:prefLabel "Physical Controls"@en .


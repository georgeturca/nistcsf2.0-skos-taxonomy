@prefix : <https://wiren301.github.io/iso27001-skos-taxonomy/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix iso27000: <https://wiren301.github.io/iso27001-skos-taxonomy/27000/> .
@prefix iso27001: <https://wiren301.github.io/iso27001-skos-taxonomy/27001/> .
@prefix iso27002: <https://wiren301.github.io/iso27001-skos-taxonomy/27002/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.1> a skos:Concept ;
    skos:definition "gatekeeping mechanisms for resource usage"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.1" ;
    skos:prefLabel "access control"@en,
        "confidentiality"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.11> a skos:Concept ;
    skos:definition "compliance state"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.11" ;
    skos:prefLabel "conformity"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.12> a skos:Concept ;
    skos:definition "key concept"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.12" ;
    skos:note "Events may result in various outcomes. | A consequence can be certain or uncertain and, in the context of information security, is usually negative. | Consequences can be expressed qualitatively or quantitatively. | Initial consequences can escalate through knock-on effects."@en ;
    skos:prefLabel "consequence"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.13> a skos:Concept ;
    skos:definition "quality pursuit"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.13" ;
    skos:prefLabel "continual improvement"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.14> a skos:Concept ;
    skos:definition "key concept"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.14" ;
    skos:note "Controls encompass processes, policies, devices, practices, and other risk-modifying actions. | It is possible that controls not always exert the intended or assumed modifying effect."@en ;
    skos:prefLabel "control"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.15> a skos:Concept ;
    skos:definition "safeguard intent"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.15" ;
    skos:prefLabel "control objective"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.16> a skos:Concept ;
    skos:definition "flaw fix"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.16" ;
    skos:prefLabel "correction"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.17> a skos:Concept ;
    skos:definition "root cause elimination"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.17" ;
    skos:prefLabel "corrective action"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.18> a skos:Concept ;
    skos:definition "computed metric"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.18" ;
    skos:prefLabel "derived measure"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.19> a skos:Concept ;
    skos:definition "preserved records"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.19" ;
    skos:note "This includes information in any format, medium, or origin. | Documented information can refer to: — the management system (3.41), including related processes (3.54); — information created in order for the organization (3.50) to operate (documentation); — evidence of results achieved (records)."@en ;
    skos:prefLabel "documented information"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.2> a skos:Concept ;
    skos:definition "hostile action"@en,
        "hostile action targeting assets"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.2" ;
    skos:prefLabel "attack"@en,
        "effectiveness"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.21> a skos:Concept ;
    skos:definition "happening"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.21" ;
    skos:note "Events may involve multiple occurrences with various causes. | An event can consist of something not happening. | An event can sometimes be referred to as an \"incident\" or \"accident\"."@en ;
    skos:prefLabel "event"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.22> a skos:Concept ;
    skos:definition "external influe"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.22" ;
    skos:note "External context encompasses cultural, social, political, legal, regulatory, financial, technological, economic, and competitive factors."@en ;
    skos:prefLabel "external context"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.23> a skos:Concept ;
    skos:definition "protection oversight structure"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.23" ;
    skos:prefLabel "governance of information security"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.24> a skos:Concept ;
    skos:definition "accountability holders"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.24" ;
    skos:note "In certain contexts, this may be a board of directors."@en ;
    skos:prefLabel "governing body"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.25> a skos:Concept ;
    skos:definition "status gauge"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.25" ;
    skos:prefLabel "indicator"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.26> a skos:Concept ;
    skos:definition "knowledge gaps to fill"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.26" ;
    skos:prefLabel "information need"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.27> a skos:Concept ;
    skos:definition "data handling venues"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.27" ;
    skos:prefLabel "information processing facilities"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.29> a skos:Concept ;
    skos:definition "uninterrupted protection"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.29" ;
    skos:prefLabel "information security continuity"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.3> a skos:Concept ;
    skos:definition "structured compliance examination"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.3" ;
    skos:note "Audits may be internal, external, or combined across multiple areas. | An internal audit is conducted by the organization itself, or by an external party on its behalf. | \"Audit evidence\" and \"audit criteria\" are defined in ISO 19011."@en ;
    skos:prefLabel "audit"@en,
        "information security event"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.31> a skos:Concept ;
    skos:definition "damaging anomaly"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.31" ;
    skos:prefLabel "information security incident"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.32> a skos:Concept ;
    skos:definition "breach handling framework"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.32" ;
    skos:prefLabel "information security incident management"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.33> a skos:Concept ;
    skos:definition "framework specialist"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.33" ;
    skos:prefLabel "information security management system (ISMS) professional"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.34> a skos:Concept ;
    skos:definition "data pooling coalition"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.34" ;
    skos:note "This may include individual persons."@en ;
    skos:prefLabel "information sharing community"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.35> a skos:Concept ;
    skos:definition "tech ecosystem"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.35" ;
    skos:prefLabel "information system"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.36> a skos:Concept ;
    skos:definition "precision plus totality"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.36" ;
    skos:prefLabel "integrity"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.37> a skos:Concept ;
    skos:definition "affected parties"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.37" ;
    skos:prefLabel "interested party (preferred term) / stakeholder (admitted term)"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.38> a skos:Concept ;
    skos:definition "internal influe"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.38" ;
    skos:note "Internal context includes governance, structure, policies, objectives, capabilities, culture, and information systems."@en ;
    skos:prefLabel "internal context"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.39> a skos:Concept ;
    skos:definition "danger magnitude"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.39" ;
    skos:prefLabel "level of risk"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.4> a skos:Concept ;
    skos:definition "review limits"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.4" ;
    skos:prefLabel "audit scope"@en,
        "likelihood"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.42> a skos:Concept ;
    skos:definition "assessed value"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.42" ;
    skos:prefLabel "measure"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.43> a skos:Concept ;
    skos:definition "valuation act"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.43" ;
    skos:prefLabel "measurement"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.44> a skos:Concept ;
    skos:definition "metric formula"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.44" ;
    skos:prefLabel "measurement function"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.45> a skos:Concept ;
    skos:definition "quantification technique"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.45" ;
    skos:note "Measurement methods may be subjective (involving human judgment) or objective (based on numerical rules)."@en ;
    skos:prefLabel "measurement method"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.46> a skos:Concept ;
    skos:definition "key concept"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.46" ;
    skos:note "To determine the status, there may be a need to check, supervise or critically observe."@en ;
    skos:prefLabel "monitoring"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.47> a skos:Concept ;
    skos:definition "key concept"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.47" ;
    skos:prefLabel "nonconformity"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.48> a skos:Concept ;
    skos:definition "action attribution proof"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.48" ;
    skos:prefLabel "non-repudiation"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.49> a skos:Concept ;
    skos:definition "key concept"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.49" ;
    skos:note "Objectives may be strategic, tactical, or operational in nature. | Objectives can relate to different disciplines (such as financial, health and safety, and environmental goals) and can apply at different levels [such as strategic, organization-wide, project, product and process (3.54)]. | An objective can be expressed in other ways, e.g. as an intended outcome, a purpose, an operational criterion, as an information security objective or by the use of other words with similar meaning (e.g. aim, goal, or target). | In the context of information security management systems, information security objectives are set by the organization, consistent with the information security policy, to achieve specific results."@en ;
    skos:prefLabel "objective"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.5> a skos:Concept ;
    skos:definition "identity claim validation"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.5" ;
    skos:note "Organizations include companies, corporations, partnerships, institutions, or combinations thereof, whether incorporated or not."@en ;
    skos:prefLabel "authentication"@en,
        "organization"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.51> a skos:Concept ;
    skos:definition "third-party delegation"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.51" ;
    skos:note "External organizations operate outside the management system scope, though their outsourced functions remain within scope."@en ;
    skos:prefLabel "outsource"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.52> a skos:Concept ;
    skos:definition "output metrics"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.52" ;
    skos:note "Results may be quantitative or qualitative in nature. | Performance can relate to the management of activities, processes (3.54), products (including services), systems or organizations (3.50)."@en ;
    skos:prefLabel "performance"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.53> a skos:Concept ;
    skos:definition "leadership directive"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.53" ;
    skos:prefLabel "policy"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.54> a skos:Concept ;
    skos:definition "workflow sequence"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.54" ;
    skos:prefLabel "process"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.55> a skos:Concept ;
    skos:definition "steady operation"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.55" ;
    skos:prefLabel "reliability"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.56> a skos:Concept ;
    skos:definition "key concept"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.56" ;
    skos:note "Implied requirements reflect customary organizational practices and stakeholder expectations. | A specified requirement is one that is stated, for example in documented information."@en ;
    skos:prefLabel "requirement"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.57> a skos:Concept ;
    skos:definition "leftover exposu"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.57" ;
    skos:note "Remaining risk may include unrecognized risks. | Residual risk can also be referred to as \"retained risk\"."@en ;
    skos:prefLabel "residual risk"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.58> a skos:Concept ;
    skos:definition "fitness examination"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.58" ;
    skos:prefLabel "review"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.59> a skos:Concept ;
    skos:definition "examination subject"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.59" ;
    skos:prefLabel "review object"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.6> a skos:Concept ;
    skos:definition "genuineness confirmation"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.6" ;
    skos:prefLabel "authenticity"@en,
        "review objective"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.61> a skos:Concept ;
    skos:definition "goal exposure"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.61" ;
    skos:note "Effects represent deviations from expectations, whether favorable or unfavorable. | Uncertainty is the state, even partial, of deficiency of information related to, understanding or knowledge of, an event, its consequence, or likelihood. | Risk is often characterized by reference to potential \"events\" (as defined in ISO Guide 73:2009, 3.5.1.3) and \"consequences\" (as defined in ISO Guide 73:2009, 3.6.1.3), or a combination of these. | Risk is often expressed in terms of a combination of the consequences of an event (including changes in circumstances) and the associated \"likelihood\" (as defined in ISO Guide 73:2009, 3.6.1.1) of occurrence. | In the context of information security management systems, information security risks can be expressed as effect of uncertainty on information security objectives. | Information security risk is associated with the potential that threats will exploit vulnerabilities of an information asset or group of information assets and thereby cause harm to an organization."@en ;
    skos:prefLabel "risk"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.62> a skos:Concept ;
    skos:definition "exposure tolerance"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.62" ;
    skos:note "Risk acceptance may occur before or during risk treatment activities. | Accepted risks are subject to monitoring (3.46) and review (3.58)."@en ;
    skos:prefLabel "risk acceptance"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.63> a skos:Concept ;
    skos:definition "danger examination"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.63" ;
    skos:note "Analysis provides the foundation for risk evaluation and treatment decisions. | Risk analysis includes risk estimation."@en ;
    skos:prefLabel "risk analysis"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.65> a skos:Concept ;
    skos:definition "stakeholder danger dialogue"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.65" ;
    skos:note "Information may address risk existence, characteristics, probability, significance, evaluation, acceptability, and treatment. | Consultation is a two-way process of informed communication between an organization (3.50) and its stakeholders on an issue prior to making a decision or determining a direction on that issue. Consultation is: — a process which impacts on a decision through influence rather than power; and — an input to decision making, not joint decision making."@en ;
    skos:prefLabel "risk communication and consultation"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.66> a skos:Concept ;
    skos:definition "danger thresholds"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.66" ;
    skos:note "Criteria derive from organizational objectives and contextual factors. | Risk criteria can be derived from standards, laws, policies (3.53) and other requirements (3.56)."@en ;
    skos:prefLabel "risk criteria"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.67> a skos:Concept ;
    skos:definition "danger acceptability judgment"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.67" ;
    skos:note "Evaluation supports risk treatment decision-making."@en ;
    skos:prefLabel "risk evaluation"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.68> a skos:Concept ;
    skos:definition "danger discovery"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.68" ;
    skos:note "This involves identifying risk sources, triggering events, causes, and potential consequences. | Risk identification can involve historical data, theoretical analysis, informed and expert opinions, and stakeholders' (3.37) needs."@en ;
    skos:prefLabel "risk identification"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.69> a skos:Concept ;
    skos:definition "danger oversight"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.69" ;
    skos:prefLabel "risk management"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.7> a skos:Concept ;
    skos:definition "ready when needed"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.7" ;
    skos:note "Related standards use 'process' for overall risk management, with individual elements termed 'activities'."@en ;
    skos:prefLabel "availability"@en,
        "risk management process"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.71> a skos:Concept ;
    skos:definition "danger accounta"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.71" ;
    skos:prefLabel "risk owner"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.72> a skos:Concept ;
    skos:definition "danger mitigation"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.72" ;
    skos:note "Risk treatment can involve: — avoiding the risk by deciding not to start or continue with the activity that gives rise to the risk; — taking or increasing risk in order to pursue an opportunity; — removing the risk source; — changing the likelihood (3.40); — changing the consequences (3.12); — sharing the risk with another party or parties (including contracts and risk financing); — retaining the risk by informed choice. | Risk treatments that deal with negative consequences are sometimes referred to as \"risk mitigation\", \"risk elimination\", \"risk prevention\" and \"risk reduction\". | Risk treatment can create new risks or modify existing risks."@en ;
    skos:prefLabel "risk treatment"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.73> a skos:Concept ;
    skos:definition "approved implementation guide"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.73" ;
    skos:prefLabel "security implementation standard"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.74> a skos:Concept ;
    skos:definition "harm potential"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.74" ;
    skos:prefLabel "threat"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.75> a skos:Concept ;
    skos:definition "executive leadership"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.75" ;
    skos:note "Senior leadership can delegate authority and allocate organizational resources. | If the scope of the management system (3.41) covers only part of an organization, then top management refers to those who direct and control that part of the organization. | Top management is sometimes called executive management and can include Chief Executive Officers, Chief Financial Officers, Chief Information Officers, and similar roles."@en ;
    skos:prefLabel "top management"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.76> a skos:Concept ;
    skos:definition "trusted intermediary"@en ;
    skos:inScheme iso27000:VocabularyScheme ;
    skos:notation "3.76" ;

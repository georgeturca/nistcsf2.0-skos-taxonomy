    skos:topConceptOf iso27001:ISMSScheme .

<https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/6.1> a skos:Concept ;
    skos:broader <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/6> ;
    skos:inScheme iso27001:ISMSScheme ;
    skos:narrower <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/6.1.1>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/6.1.2>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/6.1.3> ;
    skos:notation "6.1" ;
    skos:prefLabel "Actions to address risks and opportunities"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/7.5> a skos:Concept ;
    skos:broader <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/7> ;
    skos:inScheme iso27001:ISMSScheme ;
    skos:narrower <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/7.5.1>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/7.5.2>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/7.5.3> ;
    skos:notation "7.5" ;
    skos:prefLabel "Documented information"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/8> a skos:Concept ;
    skos:inScheme iso27001:ISMSScheme ;
    skos:narrower <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/8.1>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/8.2>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/8.3> ;
    skos:notation "8" ;
    skos:prefLabel "Operation"@en ;
    skos:topConceptOf iso27001:ISMSScheme .

<https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/9> a skos:Concept ;
    skos:inScheme iso27001:ISMSScheme ;
    skos:narrower <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/9.1>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/9.2>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/9.3> ;
    skos:notation "9" ;
    skos:prefLabel "Performance evaluation"@en ;
    skos:topConceptOf iso27001:ISMSScheme .

<https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/9.3> a skos:Concept ;
    skos:broader <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/9> ;
    skos:inScheme iso27001:ISMSScheme ;
    skos:narrower <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/9.3.1>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/9.3.2>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/9.3.3> ;
    skos:notation "9.3" ;
    skos:prefLabel "Management review"@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/4> a skos:Concept ;
    skos:inScheme iso27001:ISMSScheme ;
    skos:narrower <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/4.1>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/4.2>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/4.3>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/4.4> ;
    skos:notation "4" ;
    skos:prefLabel "Context of the organization"@en ;
    skos:topConceptOf iso27001:ISMSScheme .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/7.7> a skos:Concept ;
    skos:definition "Enforce clearing rules."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.7> ;
    skos:example "No other information."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "7.7" ;
    skos:note "Address sensitive materials."@en ;
    skos:prefLabel "Clear desk and clear screen"@en ;
    skos:scopeNote "Minimize desk and screen risks."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.11> a skos:Concept ;
    skos:definition "Mask sensitive data."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.11> ;
    skos:example "Techniques for data masking include: encryption, nulling or deleting characters, varying numbers and dates, substitution, replacing character values. Techniques for pseudonymization include: encryption, hashing, tokenization. For further information about anonymization and pseudonymization see ISO/IEC 27559."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.11" ;
    skos:note "Use appropriate techniques."@en ;
    skos:prefLabel "Data masking"@en ;
    skos:scopeNote "Limit exposure."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/7> a skos:Concept ;
    skos:inScheme iso27001:ISMSScheme ;
    skos:narrower <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/7.1>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/7.2>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/7.3>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/7.4>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/7.5> ;
    skos:notation "7" ;
    skos:prefLabel "Support"@en ;
    skos:topConceptOf iso27001:ISMSScheme .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/7.12> a skos:Concept ;
    skos:definition "Shield wiring."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.12> ;
    skos:example "No other information."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "7.12" ;
    skos:note "Segregate power and data."@en ;
    skos:prefLabel "Cabling security"@en ;
    skos:scopeNote "Prevent cable compromise."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/7.14> a skos:Concept ;
    skos:definition "Sanitize storage before reuse."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.14> ;
    skos:example "Techniques for secure overwriting of storage media differ according to the storage media technology. It is important to verify that overwriting tools are appropriate for the storage media technology."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "7.14" ;
    skos:note "Verify media presence."@en ;
    skos:prefLabel "Secure disposal or re-use of equipment"@en ;
    skos:scopeNote "Prevent data leakage."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.13> a skos:Concept ;
    skos:definition "Keep tested copies."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.13> ;
    skos:example "Backup strategies can be enhanced by storage tiering techniques which automatically move data between storage media of different costs based on access frequency or age."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.13" ;
    skos:note "Test restores."@en ;
    skos:prefLabel "Information backup"@en ;
    skos:scopeNote "Enable recovery."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.33> a skos:Concept ;
    skos:definition "Curate test data."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.33> ;
    skos:example "System and acceptance testing can require substantial volumes of test information that are as close as possible to operational information. The use of operational databases containing PII or any other confidential information for testing should be avoided."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.33" ;
    skos:note "Prefer synthetic data."@en ;
    skos:prefLabel "Test information"@en ;
    skos:scopeNote "Ensure relevance and protection."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.11> a skos:Concept ;
    skos:definition "Retrieve assets at departure."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.11> ;
    skos:example "Where equipment is not returned, it is usually considered stolen unless authorized by the organization. Depending on the circumstances, a statement about information security obligations in certain areas, such as intellectual property, can be warranted. Additional requirements for NDAs should be considered as stated in 6.6."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.11" ;
    skos:note "Formalize retrieval processes."@en ;
    skos:prefLabel "Return of assets"@en ;
    skos:scopeNote "Safeguard during transitions."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.15> a skos:Concept ;
    skos:definition "Set admission rules."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.15> ;
    skos:example "Refer to ISO/IEC 29146 for further guidance on access management."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.15" ;
    skos:note "Proportionate to dangers."@en ;
    skos:prefLabel "Access control"@en ;
    skos:scopeNote "Enable legitimate access."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.16> a skos:Concept ;
    skos:definition "Manage user accounts."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.16> ;
    skos:example "Providing or revoking access is typically a two-step process: a) establishing and authorizing an identity for the user or system; b) granting access rights to that identity. Not all persons who require an identity need access rights."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.16" ;
    skos:note "Include all users."@en ;
    skos:prefLabel "Identity management"@en ;
    skos:scopeNote "Enable identification."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.17> a skos:Concept ;
    skos:definition "Handle login secrets."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.17> ;
    skos:example "Passwords are a commonly used type of authentication information and are a common means of verifying a user's identity. Other types of authentication information are cryptographic keys, data stored on hardware tokens (e.g. smart cards) that produce authentication codes and biometric data such as iris scans or fingerprints."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.17" ;
    skos:note "Require secrecy."@en ;
    skos:prefLabel "Authentication information"@en ;
    skos:scopeNote "Strong verification."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.18> a skos:Concept ;
    skos:definition "Control admission grants."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.18> ;
    skos:example "Consideration should be given to providing business owners with the ability to make decisions about access to information or services assigned to them. IT teams often have privileged access rights that can bypass access control mechanisms which may be assigned to team members as part of privileged access rights management (see 8.2)."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.18" ;
    skos:note "Follow need-to-know principles."@en ;
    skos:prefLabel "Access rights"@en ;
    skos:scopeNote "Align access with needs."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.32> a skos:Concept ;
    skos:definition "Shield IP assets."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.32> ;
    skos:example "Intellectual property rights include software or document copyright, design rights, trademarks, patents and source code licences. Proprietary software products are usually supplied under a licence agreement that specifies licence terms and conditions, for example, limiting the use of the products to specified machines or limiting copying to the creation of backup copies only."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.32" ;
    skos:note "Address software procurement."@en ;
    skos:prefLabel "Intellectual property rights"@en ;
    skos:scopeNote "Fulfill IP duties."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.4> a skos:Concept ;
    skos:definition "Mandate directive adherence."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.4> ;
    skos:example "No other information."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.4" ;
    skos:note "Staff grasp duties before access."@en ;
    skos:prefLabel "Management responsibilities"@en ;
    skos:scopeNote "Drive staff accountability."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/6.1> a skos:Concept ;
    skos:definition "Screen personnel."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.6.1> ;
    skos:example "When an individual is hired for a specific information security role, organizations should make sure the candidate: a) has the necessary competency to perform the security role; b) can be trusted to take on the role, especially if the role is critical for the organization. Where a job, either on initial appointment or on promotion, involves the person having access to information processing facilities, and in particular if these involve handling sensitive information, e.g. financial information, PII or highly confidential information, the organization should also consider further, more detailed verification."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "6.1" ;
    skos:note "Match to risk."@en ;
    skos:prefLabel "Screening"@en ;
    skos:scopeNote "Role fitness."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/6.2> a skos:Concept ;
    skos:definition "Document job terms."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.6.2> ;
    skos:example "A code of conduct can be used to state personnel's information security responsibilities regarding confidentiality, PII protection, ethics, appropriate use of the organization's information and other associated assets, as well as reputable practices expected by the organization."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "6.2" ;
    skos:note "Address confidentiality."@en ;
    skos:prefLabel "Terms and conditions of employment"@en ;
    skos:scopeNote "Ensure duty awareness."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/6.3> a skos:Concept ;
    skos:definition "Train staff continuously."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.6.3> ;
    skos:example "When composing an information security awareness, education and training programme, it is important to not only focus on the 'what' and 'how', but also the 'why', where possible. It is important that personnel understand the aim of information security and the potential effect, positive and negative, on the organization of their own behaviour."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "6.3" ;
    skos:note "Align with policy."@en ;
    skos:prefLabel "Information security awareness, education and training"@en ;
    skos:scopeNote "Duty awareness."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/6.6> a skos:Concept ;
    skos:definition "Formalize secrecy pledges."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.6.6> ;
    skos:example "Confidentiality or non-disclosure agreements can serve to protect organizational information and inform signatories of their responsibility to protect, use and disclose information in a responsible and authorized manner."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "6.6" ;
    skos:note "Use enforceable terms."@en ;
    skos:prefLabel "Confidentiality or non-disclosure agreements"@en ;
    skos:scopeNote "Sustain confidentiality."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/6.8> a skos:Concept ;
    skos:definition "Enable anomaly reporting."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.6.8> ;
    skos:example "See the ISO/IEC 27035 series for additional information."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "6.8" ;
    skos:note "Provide easy access."@en ;
    skos:prefLabel "Information security event reporting"@en ;
    skos:scopeNote "Support timely alerts."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/7.11> a skos:Concept ;
    skos:definition "Handle power outages."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.11> ;
    skos:example "Additional redundancy for network connectivity can be obtained by means of multiple routes from more than one utility provider."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "7.11" ;
    skos:note "Consider backup power."@en ;
    skos:prefLabel "Supporting utilities"@en ;
    skos:scopeNote "Prevent disruption harm."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/7.5> a skos:Concept ;
    skos:definition "Counter environmental threats."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.5> ;
    skos:example "Examples of physical and environmental threats include: a) natural disasters: earthquake, flood, lightning, extreme weather; b) intentional attacks: arson, explosives, denial of service; c) accidents: fire spread from adjacent location, water damage from fire-fighting activities; d) social disruptions: strikes, protests, civil unrest."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "7.5" ;
    skos:note "Assess threats."@en ;
    skos:prefLabel "Protecting against physical and environmental threats"@en ;
    skos:scopeNote "Limit harm."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/7.6> a skos:Concept ;
    skos:definition "Manage secure space work."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.6> ;
    skos:example "No other information."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "7.6" ;
    skos:note "Address recording restrictions."@en ;
    skos:prefLabel "Working in secure areas"@en ;
    skos:scopeNote "Protect zone assets."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.12> a skos:Concept ;
    skos:definition "Block data leakage."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.12> ;
    skos:example "Data leakage prevention tools are designed to identify data, monitor data use and take action to prevent unauthorized transfer of data. Data leakage prevention can also be called data loss prevention or data leak prevention."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.12" ;
    skos:note "Monitor channels."@en ;
    skos:prefLabel "Data leakage prevention"@en ;
    skos:scopeNote "Detect and prevent exfiltration."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.14> a skos:Concept ;
    skos:definition "Include backup capacity."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.14> ;
    skos:example "This control also addresses whether the organization should have multiple information service providers when availability of information services is of primary concern."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.14" ;
    skos:note "Design for availability."@en ;
    skos:prefLabel "Redundancy of information processing facilities"@en ;
    skos:scopeNote "Ensure continuity."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.17> a skos:Concept ;
    skos:definition "Sync timestamps."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.17> ;
    skos:example "The correct setting of computer clocks is important to ensure the accuracy of event logs, which can be required for investigations or as evidence in legal or disciplinary cases. Inaccurate event logs can hamper such investigations and damage the credibility of such evidence."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.17" ;
    skos:note "Use authoritative sources."@en ;
    skos:prefLabel "Clock synchronization"@en ;
    skos:scopeNote "Enable event correlation."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.21> a skos:Concept ;
    skos:definition "Define service safety."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.21> ;
    skos:example "Network services include the provision of connections, private network services, value-added networks and managed network security solutions such as firewalls and intrusion detection systems. These services can range from simple unmanaged bandwidth to complex value-added offerings. Additional information on network security can be found in the ISO/IEC 27033 series."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.21" ;
    skos:note "Include in agreements."@en ;
    skos:prefLabel "Security of network services"@en ;
    skos:scopeNote "Ensure service security."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.22> a skos:Concept ;
    skos:definition "Segment networks."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.22> ;
    skos:example "Networks can extend beyond organizational premises due to partnerships requiring interconnection or sharing of information processing and networking facilities. Such extensions can increase the risk of unauthorized access to the organization's existing information systems that use the network, some of which require protection from other network users because of their sensitivity or criticality."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.22" ;
    skos:note "Zone by trust."@en ;
    skos:prefLabel "Segregation of networks"@en ;
    skos:scopeNote "Trust boundaries."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.23> a skos:Concept ;
    skos:definition "Restrict browsing."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.23> ;
    skos:example "Web filtering techniques include: heuristics, signature matching, allowlisting and blocklisting, configuring domain name services to block malicious domains, configuring endpoints to check URLs with a web filtering service on the Internet, implementing a proxy to filter access to websites based on URL or content, configuring browsers to use safe web browsing lists which are lists that block malicious sites."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.23" ;
    skos:note "Filter sites."@en ;
    skos:prefLabel "Web filtering"@en ;
    skos:scopeNote "Block web threats."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.24> a skos:Concept ;
    skos:definition "Formalize encryption rules."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.24> ;
    skos:example "Cryptography can be used to achieve different information security objectives, for example: a) confidentiality: using encryption of information to protect sensitive or critical information; b) integrity or authenticity: using digital signatures or message authentication codes to verify the authenticity or integrity of sensitive or critical information; c) non-repudiation: using cryptographic techniques to provide evidence that an event or action has or has not occurred; d) authentication: using cryptographic techniques to authenticate users and other system entities requesting access to system resources."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.24" ;
    skos:note "Address key handling."@en ;
    skos:prefLabel "Use of cryptography"@en ;
    skos:scopeNote "Ensure proper crypto use."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.5> a skos:Concept ;
    skos:definition "Match verification to sensitivity."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.5> ;
    skos:example "The log-on process should be designed to minimize the opportunity for unauthorized access, for example by disclosing minimum information about the system, to avoid providing an unauthorized user with unnecessary assistance. An appropriate log-on procedure should: a) not display application identifiers until the log-on process has been successfully completed; b) display a general notice warning that the computer should only be accessed by authorized users; c) not provide help messages during the log-on procedure that would aid an unauthorized user; d) validate the log-on information only on completion of all input data, and if an error condition arises, not indicate which part of the data is correct or incorrect; e) protect against brute force attacks; f) log unsuccessful and successful attempts; g) raise an information security event if a potential attempted or successful breach of log-on controls is detected."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.5" ;
    skos:note "Use strong methods where needed."@en ;
    skos:prefLabel "Secure authentication"@en ;
    skos:scopeNote "Ensure secure confirmation."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.9> a skos:Concept ;
    skos:definition "Standardize settings."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.9> ;
    skos:example "For further information see ISO/IEC 19770-1 for IT asset management and ISO/IEC 19770-5 for overview and vocabulary. For additional guidance on audit and configuration management, see ISO/IEC TS 27008."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.9" ;
    skos:note "Enforce defined configs."@en ;
    skos:prefLabel "Configuration management"@en ;
    skos:scopeNote "Ensure proper function."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.12> a skos:Concept ;
    skos:definition "Tier data by sensitivity."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.12> ;
    skos:example "Classification provides people who deal with information with a concise indication of how to handle and protect it. Creating groups of information with similar protection needs and specifying information security procedures that apply to all the information in each group facilitates this."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.12" ;
    skos:note "Include review triggers."@en ;
    skos:prefLabel "Classification of information"@en ;
    skos:scopeNote "Identify protection needs."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.13> a skos:Concept ;
    skos:definition "Apply matching labels."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.13> ;
    skos:example "Information classified as confidential or sensitive can be a target for malicious internal or external access. Labelling classified information can draw attention to it. For this reason, some organizations choose not to label information classified at a certain level, relying on training and awareness to communicate the classification level."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.13" ;
    skos:note "Cover all formats."@en ;
    skos:prefLabel "Labelling of information"@en ;
    skos:scopeNote "Enable classification communication."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.14> a skos:Concept ;
    skos:definition "Govern data movement."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.14> ;
    skos:example "Information can be transferred through the use of a number of different types of communication facilities, including electronic, physical and verbal."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.14" ;
    skos:note "Match protection to classification."@en ;
    skos:prefLabel "Information transfer"@en ;
    skos:scopeNote "Preserve transfer security."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.19> a skos:Concept ;
    skos:definition "Address vendor dangers."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.19> ;
    skos:example "When not properly managed, information security risks associated with suppliers can lead to compromises of information and other associated assets of the organization. Suppliers include service providers."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.19" ;
    skos:note "Cover cloud arrangements."@en ;
    skos:prefLabel "Information security in supplier relationships"@en ;
    skos:scopeNote "Sustain relationship security."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.21> a skos:Concept ;
    skos:definition "Manage supply chain dangers."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.21> ;
    skos:example "ICT supply chain risks for an organization can stem from: a) purchase or use of counterfeit hardware or hardware with embedded malware; b) vulnerabilities in software components or services provided to the organization, whether obtained through supplier or other sources; c) outsourced application development; d) disclosure or leakage of business- or customer-sensitive information by supply chain participants; e) intentional or unintentional introduction of malware or backdoors or unauthorized features into delivered items."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.21" ;
    skos:note "Assess pre-acquisition."@en ;
    skos:prefLabel "Managing information security in the information and communication technology (ICT) supply chain"@en ;
    skos:scopeNote "Sustain relationship security."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.23> a skos:Concept ;
    skos:definition "Govern cloud usage."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.23> ;
    skos:example "See the ISO/IEC 27017 for more detailed information about information security for cloud services."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.23" ;
    skos:note "Apply across service models."@en ;
    skos:prefLabel "Information security for use of cloud services"@en ;
    skos:scopeNote "Specify cloud security."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.25> a skos:Concept ;
    skos:definition "Classify anomalies."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.25> ;
    skos:example "The ISO/IEC 27035 series provides further guidance on incident management."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.25" ;
    skos:note "Use clear criteria."@en ;
    skos:prefLabel "Assessment and decision on information security events"@en ;
    skos:scopeNote "Enable effective triage."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.26> a skos:Concept ;
    skos:definition "Act on breaches."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.26> ;
    skos:example "The ISO/IEC 27035 series provides further guidance on incident management."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.26" ;
    skos:note "Use competent teams."@en ;
    skos:prefLabel "Response to information security incidents"@en ;
    skos:scopeNote "Enable efficient resolution."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.27> a skos:Concept ;
    skos:definition "Apply breach lessons."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.27> ;
    skos:example "The ISO/IEC 27035 series provides further guidance on incident management."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.27" ;
    skos:note "Inform enhanced controls."@en ;
    skos:prefLabel "Learning from information security incidents"@en ;
    skos:scopeNote "Reduce future incidents."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.28> a skos:Concept ;
    skos:definition "Standardize forensics."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.28> ;
    skos:example "When an information security event is first detected, it is not always obvious whether or not the event will result in court action. Therefore, the danger exists that necessary evidence is destroyed intentionally or accidentally before the seriousness of the incident is realized. It is advisable to involve a lawyer or police early in any contemplated legal action and take advice on the evidence required. For further guidance on digital evidence see ISO/IEC 27037, ISO/IEC 27041, ISO/IEC 27042 and ISO/IEC 27043."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.28" ;
    skos:note "Cover all media types."@en ;
    skos:prefLabel "Collection of evidence"@en ;
    skos:scopeNote "Enable consistent evidence handling."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.31> a skos:Concept ;
    skos:definition "Note legal duties."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.31> ;
    skos:example "Cryptography is an area that often has specific legal requirements. Compliance with legislation governing the use of cryptographic measures should be considered."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.31" ;
    skos:note "Track changes."@en ;
    skos:prefLabel "Legal, statutory, regulatory and contractual requirements"@en ;
    skos:scopeNote "Meet compliance."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.35> a skos:Concept ;
    skos:definition "Conduct independent reviews."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.35> ;
    skos:example "ISO/IEC 27007 and ISO/IEC TS 27008 provide guidance for carrying out independent reviews."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.35" ;
    skos:note "Identify enhancement prospects."@en ;
    skos:prefLabel "Independent review of information security"@en ;
    skos:scopeNote "Ensure sustained fitness."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.9> a skos:Concept ;
    skos:definition "Maintain asset catalogs."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.9> ;
    skos:example "The inventory of information and other associated assets is an essential prerequisite for information security risk management (see also ISO/IEC 27005)."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.9" ;
    skos:note "Keep inventories current."@en ;
    skos:prefLabel "Inventory of information and other associated assets"@en ;
    skos:scopeNote "Enable protection and accountability."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/6.4> a skos:Concept ;
    skos:definition "Handle breaches formally."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.6.4> ;
    skos:example "The disciplinary process can also serve as a deterrent to prevent personnel and other relevant interested parties from violating the organization's information security policy, topic-specific policies and procedures for information security."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "6.4" ;
    skos:note "Graduate responses."@en ;
    skos:prefLabel "Disciplinary process"@en ;
    skos:scopeNote "Ensure consequence awareness."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/6.5> a skos:Concept ;
    skos:definition "Specify departure duties."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.6.5> ;
    skos:example "The human resources function is generally responsible for the overall termination process and works together with the supervising manager of the person leaving to manage the information security aspects of the relevant procedures. In the case of personnel provided by an external party (e.g. through a staffing organization), this process of termination is undertaken by the external party in accordance with the contract between the organization and the external party. It can be necessary to inform personnel and other interested parties of changes in personnel and operating arrangements."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "6.5" ;
    skos:note "Include ongoing obligations."@en ;
    skos:prefLabel "Responsibilities after termination or change of employment"@en ;
    skos:scopeNote "Protect during transitions."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/7.1> a skos:Concept ;
    skos:definition "Mark protected zones."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.1> ;
    skos:example "Damage can result from degradation of media used to store information. See ISO/IEC 27040 for detail on methods for sanitizing storage media."@en,
        "Physical protection can be achieved by creating one or more physical barriers around the organization's premises and information processing facilities. A secure area can be a lockable office or several rooms surrounded by a continuous internal physical security barrier. Additional barriers and perimeters to control physical access can be necessary between areas with different security requirements inside the security perimeter."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "7.1" ;
    skos:note "Address boundary soundness."@en ;
    skos:prefLabel "Physical security perimeters"@en,
        "Storage media"@en ;
    skos:scopeNote "Block unauthorized entry."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/7.2> a skos:Concept ;
    skos:definition "Manage doorways."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.2> ;
    skos:example "No other information."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "7.2" ;
    skos:note "Separate deliveries."@en ;
    skos:prefLabel "Physical entry"@en ;
    skos:scopeNote "Limit entry."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/7.3> a skos:Concept ;
    skos:definition "Design workspace protection."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.3> ;
    skos:example "No other information."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "7.3" ;
    skos:note "Minimize exposure."@en ;
    skos:prefLabel "Securing offices, rooms and facilities"@en ;
    skos:scopeNote "Block unauthorized access."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/7.8> a skos:Concept ;
    skos:definition "Arrange gear wisely."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.8> ;
    skos:example "No other information."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "7.8" ;
    skos:note "Block hazards."@en ;
    skos:prefLabel "Equipment siting and protection"@en ;
    skos:scopeNote "Reduce exposure."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/7.9> a skos:Concept ;
    skos:definition "Defend mobile equipment."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.9> ;
    skos:example "Equipment and storage media taken off-premises can be exposed to risks at a greater level than on-site equipment. Storage media includes all types of removable and internal, connected storage."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "7.9" ;
    skos:note "Get approval."@en ;
    skos:prefLabel "Security of assets off-premises"@en ;
    skos:scopeNote "Off-site safety."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.15> a skos:Concept ;
    skos:definition "Capture event trails."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.15> ;
    skos:example "Event logs can contain sensitive data and PII. Appropriate privacy-protecting measures should be taken. Where possible, system administrators should not have permission to erase or deactivate logs of their own activities."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.15" ;
    skos:note "Log key actions."@en ;
    skos:prefLabel "Logging"@en ;
    skos:scopeNote "Investigation support."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.16> a skos:Concept ;
    skos:definition "Watch for anomalies."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.16> ;
    skos:example "The use of specialized, automated tools for monitoring activities is often necessary due to the amount of information typically generated, the criticality of timely reaction and the complexity of information systems and networks. Specialized tools such as EDR (endpoint detection and response), XDR (extended detection and response), SIEM (security information and event management) and UEBA (user and entity behaviour analytics) can support monitoring activities."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.16" ;
    skos:note "Match scope to needs."@en ;
    skos:prefLabel "Monitoring activities"@en ;
    skos:scopeNote "Detect incidents."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.19> a skos:Concept ;
    skos:definition "Secure live deployments."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.19> ;
    skos:example "Vendor supplied software used in operational systems should be maintained at a level supported by the supplier. Over time, software vendors cease to support older versions of software. The organization should consider the risks of relying on unsupported software."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.19" ;
    skos:note "Use trained staff."@en ;
    skos:prefLabel "Installation of software on operational systems"@en ;
    skos:scopeNote "Ensure production integrity."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.25> a skos:Concept ;
    skos:definition "Bake in dev security."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.25> ;
    skos:example "Development can also be conducted within applications (e.g. office applications, scripting and browsers). Guidance on security considerations in software development methodologies can be found in the ISO/IEC 27034 series."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.25" ;
    skos:note "Test security."@en ;
    skos:prefLabel "Secure development life cycle"@en ;
    skos:scopeNote "Secure throughout."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.27> a skos:Concept ;
    skos:definition "Follow secure architecture."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.27> ;
    skos:example "Secure system architecture and engineering principles include but are not limited to: zero trust architecture, defence in depth, secure by design and by default, least privilege, separation of concerns, fail securely, security in design, and privacy by design."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.27" ;
    skos:note "Analyze new tech dangers."@en ;
    skos:prefLabel "Secure system architecture and engineering principles"@en ;
    skos:scopeNote "Ensure secure design."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.28> a skos:Concept ;
    skos:definition "Craft resilient code."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.28> ;
    skos:example "The OWASP secure coding practices quick reference guide provides a checklist that can be integrated into the development lifecycle. OWASP also provides a list of top 10 application security risks and associated guidance on how to avoid these."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.28" ;
    skos:note "Establish coding governance."@en ;
    skos:prefLabel "Secure coding"@en ;
    skos:scopeNote "Minimize code weaknesses."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.31> a skos:Concept ;
    skos:definition "Wall off build phases."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.31> ;
    skos:example "Development and testing activities can cause serious problems, e.g. unwanted modification of files or system environment, or system failure. A known level of separation between production, testing and development environments is necessary to reduce the risk of accidental change or unauthorized access to operational software and business data."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.31" ;
    skos:note "Limit transfers."@en ;
    skos:prefLabel "Separation of development, test and production environments"@en ;
    skos:scopeNote "Shield production."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.32> a skos:Concept ;
    skos:definition "Govern modifications."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.32> ;
    skos:example "System changes affect applications, databases, operating systems, network devices, and their configuration. Inadequately controlled changes are a common cause of security and operational incidents. Changes to production systems should be kept to a minimum. Non-essential changes should be delayed until a change window or downtime period."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.32" ;
    skos:note "Test changes."@en ;
    skos:prefLabel "Change management"@en ;
    skos:scopeNote "Change safety."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.24> a skos:Concept ;
    skos:definition "Pre-plan breach response."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.24> ;
    skos:example "Information security incidents can transcend organizational and national boundaries. To respond to such incidents, it is beneficial to coordinate response and share information about these incidents with external organizations as appropriate. Detailed guidance on information security incident management is provided in the ISO/IEC 27035 series."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.24" ;
    skos:note "Establish roles and duties."@en ;
    skos:prefLabel "Information security incident management planning and preparation"@en ;
    skos:scopeNote "Enable rapid handling."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.29> a skos:Concept ;
    skos:definition "Preserve safety through crises."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.29> ;
    skos:example "Business continuity plans or disaster recovery plans can contain information security requirements that can be useful to meet this control. Information to support this can be found in ISO 22301 and ISO 22313."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.29" ;
    skos:note "Plan ahead."@en ;
    skos:prefLabel "Information security during disruption"@en ;
    skos:scopeNote "Crisis protection."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.34> a skos:Concept ;
    skos:definition "Honor privacy rules."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.34> ;
    skos:example "Compliance with this control means that the information security aspects of the protection of PII should be fulfilled. Several countries and regions have introduced legislation placing controls on the collection, processing, transmission and deletion of PII. Depending on the applicable national legislation, such controls can impose duties on those collecting, processing and transmitting PII, and can also restrict the trans-border transfer of PII. ISO/IEC 27701 provides guidance on privacy information management."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.34" ;
    skos:note "Communicate to handlers."@en ;
    skos:prefLabel "Privacy and protection of PII"@en ;
    skos:scopeNote "Fulfill privacy duties."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.36> a skos:Concept ;
    skos:definition "Verify directive adherence."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.36> ;
    skos:example "Operational monitoring of system use is covered in 8.15, 8.16, 8.17."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.36" ;
    skos:note "Consider automation."@en ;
    skos:prefLabel "Compliance with policies, rules and standards for information security"@en ;
    skos:scopeNote "Ensure proper operations."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.6> a skos:Concept ;
    skos:definition "Join professional networks."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.6> ;
    skos:example "No other information."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.6" ;
    skos:note "Forums aid best practice awareness."@en ;
    skos:prefLabel "Contact with special interest groups"@en ;
    skos:scopeNote "Enable knowledge pooling."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.8> a skos:Concept ;
    skos:definition "Weave defenses through work."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.8> ;
    skos:example "All projects can be considered either to carry information or other associated assets (and be supported by ICT). Therefore, information security requirements should be considered as part of project management from the beginning. Project methodologies in use should require that: a) information security objectives are included in project objectives; b) an information security risk assessment is conducted at early stages of the project to identify necessary controls; c) information security is part of all phases of the applied project methodology."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.8" ;
    skos:note "Start early."@en ;
    skos:prefLabel "Information security in project management"@en ;
    skos:scopeNote "Project protection."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/7.13> a skos:Concept ;
    skos:definition "Maintain gear properly."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.13> ;
    skos:example "No other information."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "7.13" ;
    skos:note "Follow vendor guidance."@en ;
    skos:prefLabel "Equipment maintenance"@en ;
    skos:scopeNote "Prevent maintenance harm."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/7.4> a skos:Concept ;
    skos:definition "Watch for intruders."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.7.4> ;
    skos:example "The design of monitoring systems is confidential in nature. Care should be taken so that the threat of spoofing of monitoring systems by attackers is mitigated through measures such as making the designs of surveillance systems and the location of cameras confidential."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "7.4" ;
    skos:note "Focus on critical areas."@en ;
    skos:prefLabel "Physical security monitoring"@en ;
    skos:scopeNote "Detect and deter."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.1> a skos:Concept ;
    skos:definition "Safeguard device data."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.1> ;
    skos:example "BYOD guidance: Where the organization allows the use of personal devices, the following should be considered: a) separation of personal and business use of the devices, including using software to support such separation and protect business data on a private device; b) providing access to business information only after users have acknowledged their duties; c) topic-specific policies and procedures to prevent disputes concerning rights to intellectual property developed on privately owned equipment; d) access to privately owned equipment (to verify the security of the machine or during an investigation), which can be prevented by legislation; e) software licensing agreements."@en,
        "Suppliers of cloud services typically do not ensure the deletion of the organization's information at an infrastructure layer so use of client-based tools (e.g. cryptographic erasure) should be considered."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.1" ;
    skos:note "Address device types."@en ;
    skos:prefLabel "Information deletion"@en,
        "User endpoint devices"@en ;
    skos:scopeNote "Shield from device dangers."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.18> a skos:Concept ;
    skos:definition "Restrict admin tools."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.18> ;
    skos:example "Most information systems have one or more utility programs that can be capable of overriding system and application controls, for example diagnostics, patching, antivirus, disk defragmenters, debuggers, backup and network tools."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.18" ;
    skos:note "Limit to authorized staff."@en ;
    skos:prefLabel "Use of privileged utility programs"@en ;
    skos:scopeNote "Prevent control bypass."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.2> a skos:Concept ;
    skos:definition "Curb admin access."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.2> ;
    skos:example "Additional information on network security can be found in the ISO/IEC 27033 series. Further information on networks can be found in ISO/IEC TS 27034-6."@en,
        "Inappropriate allocation and use of system administration privileges can be a major contributory factor to the failure or breach of systems. See also 8.18 for privileged utility programs."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.2" ;
    skos:note "Log usage."@en ;
    skos:prefLabel "Networks security"@en,
        "Privileged access rights"@en ;
    skos:scopeNote "Limit privileged parties."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.26> a skos:Concept ;
    skos:definition "Capture protection needs early."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.26> ;
    skos:example "ISO/IEC 27034-1 provides detailed information about application security."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.26" ;
    skos:note "Include validation needs."@en ;
    skos:prefLabel "Application security requirements"@en ;
    skos:scopeNote "Address development security."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.29> a skos:Concept ;
    skos:definition "Embed safety checks."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.29> ;
    skos:example "Security testing methodologies include both automated and manual techniques, and can include: a) static application security testing (SAST) and dynamic application security testing (DAST); b) automated or manual threat modelling; c) vulnerability scanning; d) penetration testing. Additional guidance on security testing techniques can be found in ISO/IEC 27034-1."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.29" ;
    skos:note "Make integral to testing."@en ;
    skos:prefLabel "Security testing in development and acceptance"@en ;
    skos:scopeNote "Verify before deployment."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.34> a skos:Concept ;
    skos:definition "Minimize audit disruption."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.34> ;
    skos:example "Audit and other assurance activities can include technical testing such as vulnerability assessment and penetration testing."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.34" ;
    skos:note "Prefer read-only access."@en ;
    skos:prefLabel "Protection of information systems during audit testing"@en ;
    skos:scopeNote "Reduce operational impact."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.4> a skos:Concept ;
    skos:definition "Control code access."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.4> ;
    skos:example "No other information."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.4" ;
    skos:note "Maintain audit trails."@en ;
    skos:prefLabel "Access to source code"@en ;
    skos:scopeNote "Block unauthorized changes."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.6> a skos:Concept ;
    skos:definition "Monitor resource usage."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.6> ;
    skos:example "A documented capacity management plan should be considered for mission critical systems."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.6" ;
    skos:note "Plan ahead."@en ;
    skos:prefLabel "Capacity management"@en ;
    skos:scopeNote "Ensure capacity."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.2> a skos:Concept ;
    skos:definition "Assign duties."@en,
        "Map duties to personnel."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.2> ;
    skos:example "Many organizations appoint an information security manager to take overall responsibility for the development and implementation of information security and to support the identification of risks and mitigating controls. However, responsibility for resourcing and implementing the controls often remains with individual managers. One common practice is to appoint an owner for each asset who then becomes responsible for its day-to-day protection."@en,
        "See ISO/IEC 27036 for more detailed information about information security in supplier relationships."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.2" ;
    skos:note "Assignments support directives."@en ;
    skos:prefLabel "Addressing information security within supplier agreements"@en,
        "Information security roles and responsibilities"@en ;
    skos:scopeNote "Build clear accountability."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.22> a skos:Concept ;
    skos:definition "Review vendor work."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.22> ;
    skos:example "See also the ISO/IEC 27036 series."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.22" ;
    skos:note "Check compliance."@en ;
    skos:prefLabel "Monitoring, review and change management of supplier services"@en ;
    skos:scopeNote "Maintain levels."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.33> a skos:Concept ;
    skos:definition "Guard stored records."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.33> ;
    skos:example "Records can be needed to document: a) that the organization is meeting legal, statutory, regulatory or contractual obligations; b) that adequate defence can be provided in any potential civil or criminal action; c) that the financial status of an organization can be confirmed to stakeholders."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.33" ;
    skos:note "Include disposal."@en ;
    skos:prefLabel "Protection of records"@en ;
    skos:scopeNote "Meet obligations."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.7> a skos:Concept ;
    skos:definition "Gather threat data."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.7> ;
    skos:example "Organizations can use threat intelligence to prevent, detect, or respond to threats. Organizations can produce threat intelligence, but more typically receive and make use of threat intelligence produced by other sources. Threat intelligence is often provided by independent providers or advisors, government agencies or collaborative threat intelligence groups. The effectiveness of controls such as 5.25, 8.7, 8.16 or 8.23, depends on the quality of available threat intelligence."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.7" ;
    skos:note "Cover all levels."@en ;
    skos:prefLabel "Threat intelligence"@en ;
    skos:scopeNote "Landscape awareness."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/6.7> a skos:Concept ;
    skos:definition "Secure remote work."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.6.7> ;
    skos:example "Remote working refers to all forms of work outside of the office, including non-traditional work environments, such as those referred to as 'teleworking', 'telecommuting', 'flexible workplace', 'virtual work environments' and 'remote maintenance'."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "6.7" ;
    skos:note "Address physical and logical needs."@en ;
    skos:prefLabel "Remote working"@en ;
    skos:scopeNote "Ensure off-site protection."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.7> a skos:Concept ;
    skos:definition "Fight malicious software."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.7> ;
    skos:example "It is not always possible to install software that protects against malware on some systems (e.g. some industrial control systems). Some forms of malware infect computer operating systems and computer firmware such that common malware controls cannot clean the system and a full reimaging of the operating system software and sometimes the computer firmware is necessary to return to a secure state."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.7" ;
    skos:note "Train users too."@en ;
    skos:prefLabel "Protection against malware"@en ;
    skos:scopeNote "Block malware."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.8> a skos:Concept ;
    skos:definition "Track and fix weaknesses."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.8> ;
    skos:example "Many organizations supply software, systems, products and services not only within the organization but also to interested parties such as customers, partners or other users. These software, systems, products and services can have information security vulnerabilities that affect the security of users. Organizations can release remediation and disclose information about vulnerabilities to users (typically through a public advisory) and provide appropriate information for software vulnerability database services. For more information relating to the management of technical vulnerabilities when using cloud computing, see the ISO/IEC 19086 series and ISO/IEC 27017."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.8" ;
    skos:note "Use multiple sources."@en ;
    skos:prefLabel "Management of technical vulnerabilities"@en ;
    skos:scopeNote "Block exploitation."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.3> a skos:Concept ;
    skos:definition "Distribute clashing tasks."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.3> ;
    skos:example "Business continuity plans can contain information security requirements that can be useful to meet this control. Guidance can be found in ISO/IEC 27031 and ISO 22301. Further guidance on BIA can be found in ISO/TS 22317."@en,
        "No other information."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.3" ;
    skos:note "Collusion-prone tasks need splitting."@en ;
    skos:prefLabel "ICT readiness for business continuity"@en,
        "Segregation of duties"@en ;
    skos:scopeNote "Block fraud and errors."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.5> a skos:Concept ;
    skos:definition "Cultivate oversight ties."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.5> ;
    skos:example "Organizations under attack can request authorities to take action against the attack source. Maintaining such contacts can be a requirement to support information security incident management (see 5.24 to 5.28) or the contingency planning and business continuity processes (see 5.29 and 5.30). Contacts with regulatory bodies are also useful to anticipate and prepare for upcoming changes in relevant laws or regulations that affect the organization. Contacts with other authorities include utilities, emergency services, electricity suppliers and health and safety [e.g. fire departments (in connection with business continuity), telecommunication providers (in connection with line routing and availability) and water suppliers (in connection with cooling facilities for equipment)]."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.5" ;
    skos:note "Define protocols."@en ;
    skos:prefLabel "Contact with authorities"@en ;
    skos:scopeNote "Enable information flow."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.1> a skos:Concept ;
    skos:definition "Issue and share directives."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.1> ;
    skos:example "Topic-specific policies can vary across organizations."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.1" ;
    skos:note "Get approval."@en ;
    skos:prefLabel "Acceptable use of information and other associated assets"@en,
        "Policies for information security"@en ;
    skos:scopeNote "Leadership guidance."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/8.3> a skos:Concept ;
    skos:definition "Follow admission rules."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.8.3> ;
    skos:example "More information can be found in ISO/IEC 27036-3."@en,
        "No other information."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "8.3" ;
    skos:note "Limit output data."@en ;
    skos:prefLabel "Information access restriction"@en,
        "Outsourced development"@en ;
    skos:scopeNote "Block unauthorized access."@en .

<https://wiren301.github.io/iso27001-skos-taxonomy/27002/control/5.37> a skos:Concept ;
    skos:definition "Keep procedure docs."@en ;
    skos:exactMatch <https://wiren301.github.io/iso27001-skos-taxonomy/27001/control/A.5.37> ;
    skos:example "No other information."@en ;
    skos:inScheme iso27002:ControlsScheme ;
    skos:notation "5.37" ;
    skos:note "Share widely."@en ;
    skos:prefLabel "Documented operating procedures"@en ;
    skos:scopeNote "Proper operations."@en .

iso27001:ISMSScheme a skos:ConceptScheme ;
    dct:created "2026-06-03"^^xsd:date ;
    dct:description "Information Security Management System requirements organized by clause"@en ;
    skos:hasTopConcept <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/1>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/10>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/2>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/3>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/4>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/5>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/6>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/7>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/8>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/clause/9> ;
    skos:prefLabel "ISO/IEC 27001:2022 ISMS Requirements"@en .

iso27000:VocabularyScheme a skos:ConceptScheme ;
    dct:created "2026-06-03"^^xsd:date ;
    dct:description "77 terms and definitions for information security management systems"@en ;
    skos:hasTopConcept <https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.28>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.41>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27000/term/3.64> ;
    skos:prefLabel "ISO/IEC 27000:2018 Information Security Vocabulary"@en .

iso27002:ControlsScheme a skos:ConceptScheme ;
    dct:created "2026-06-03"^^xsd:date ;
    dct:description "93 controls with detailed guidance and attribute classifications"@en ;
    skos:prefLabel "ISO/IEC 27002:2022 Information Security Controls"@en .

iso27001:AnnexAScheme a skos:ConceptScheme ;
    dct:created "2026-06-03"^^xsd:date ;
    dct:description "93 information security controls organized by theme"@en ;
    skos:hasTopConcept <https://wiren301.github.io/iso27001-skos-taxonomy/27001/collection/organizational>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/collection/people>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/collection/physical>,
        <https://wiren301.github.io/iso27001-skos-taxonomy/27001/collection/technological> ;
    skos:prefLabel "ISO/IEC 27001:2022 Annex A Controls"@en .


#[Deprecated] This one is not in use 

@prefix csf: <https://example.org/nist-csf-2.0/concept/> .
@prefix csfscheme: <https://example.org/nist-csf-2.0/scheme/> .
@prefix csfprop: <https://example.org/nist-csf-2.0/property/> .
@prefix csfref: <https://example.org/nist-csf-2.0/reference/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

csfscheme:core a skos:ConceptScheme ;
    skos:prefLabel "NIST Cybersecurity Framework 2.0 Core"@en ;
    dcterms:source "NIST Cybersecurity Framework 2.0 Reference Tool"@en .

csf:GV a skos:Concept ;
    skos:inScheme csfscheme:core ;
    skos:topConceptOf csfscheme:core ;
    skos:notation "GV" ;
    dcterms:type "Function" ;
    skos:prefLabel "Govern"@en ;
    skos:definition "The organization's cybersecurity risk management strategy, expectations, and policy are established, communicated, and monitored."@en .

csfscheme:core skos:hasTopConcept csf:GV .

csf:GV-OC a skos:Concept ;
    skos:inScheme csfscheme:core ;
    skos:notation "GV.OC" ;
    dcterms:type "Category" ;
    skos:prefLabel "Organizational Context"@en ;
    skos:definition "The circumstances surrounding the organization's cybersecurity risk management decisions are understood."@en ;
    skos:broader csf:GV .

csf:GV skos:narrower csf:GV-OC .

csf:GV-OC-01 a skos:Concept ;
    skos:inScheme csfscheme:core ;
    skos:notation "GV.OC-01" ;
    dcterms:type "Subcategory" ;
    skos:prefLabel "The organizational mission is understood and informs cybersecurity risk management."@en ;
    skos:definition "The organizational mission is understood and informs cybersecurity risk management."@en ;
    skos:broader csf:GV-OC ;
    csfprop:implementationExample "Example implementation text here."@en ;
    csfprop:informativeReferenceText "SCF: BCD-01; NICE Framework: DD-WRL-002"@en ;
    csfprop:hasInformativeReference csfref:scf-BCD-01 .

csf:GV-OC skos:narrower csf:GV-OC-01 .

csfref:scf-BCD-01 a csfprop:InformativeReference ;
    skos:prefLabel "SCF: BCD-01"@en ;
    skos:notation "BCD-01" ;
    dcterms:source "Secure Controls Framework"@en ;
    rdfs:seeAlso <https://scfconnect.com/controls/bcd/bcd-01> .
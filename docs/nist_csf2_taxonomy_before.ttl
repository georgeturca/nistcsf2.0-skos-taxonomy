        csfref:NICE-Framework-OG-WRL-005,
        csfref:OWASP-Top-10-LLM-Applications-LLM01-2025,
        csfref:OWASP-Top-10-LLM-Applications-LLM02-2025,
        csfref:OWASP-Top-10-LLM-Applications-LLM09-2025,
        csfref:PCI-DSS-12-6-1,
        csfref:PCI-DSS-12-6-3,
        csfref:SCF-SAT-02,
        csfref:SCF-SAT-03,
        csfref:SCF-SAT-03-6,
        csfref:SP-800-171-Rev-3-03-02-02,
        csfref:SP-800-221A-GV-CT-3,
        csfref:SP-800-221A-GV-RR-2,

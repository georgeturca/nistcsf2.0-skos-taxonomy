        csfref:NICE-Framework-IO-WRL-002,
        csfref:NICE-Framework-IO-WRL-005,
        csfref:NICE-Framework-OG-WRL-002,
        csfref:NICE-Framework-OG-WRL-007,
        csfref:NICE-Framework-OG-WRL-009,
        csfref:NICE-Framework-OG-WRL-010,
        csfref:NICE-Framework-OG-WRL-011,
        csfref:NICE-Framework-OG-WRL-014,
        csfref:NICE-Framework-OG-WRL-015,
        csfref:NICE-Framework-PD-WRL-003,
        csfref:NICE-Framework-PD-WRL-004,
        csfref:SCF-BCD-01,
        csfref:SCF-BCD-01-4,
        csfref:SCF-BCD-02,
        csfref:SCF-BCD-02-1,
        csfref:SP-800-53-Rev-5-1-1-CP-04,
        csfref:SP-800-53-Rev-5-1-1-CP-10,

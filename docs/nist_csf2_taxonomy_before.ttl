csf:ID-IM-01 a skos:Concept ;
    dcterms:type "Subcategory" ;
    skos:broader csf:ID-IM ;
    skos:definition "Verbesserungen werden anhand von Bewertungen ermittelt."@de,
        "Εντοπίζονται βελτιώσεις από τις αξιολογήσεις"@el,
        "Improvements are identified from evaluations"@en,
        "Las mejoras se identifican a partir de evaluaciones"@es,
        "Les améliorations sont identifiées à partir des évaluations"@fr,
        "改善点が評価から識別されている。"@ja,
        "평가에서 개선 사항을 식별합니다."@ko,
        "Evalueringer brukes for å identifisere forbedringer"@no,
        "udoskonalenia są identyfikowane na podstawie ocen."@pl,
        "As melhorias são identificadas a partir de avaliações"@pt,
        "มีการระบุเรื่องที่ตอ้ งปรับปรุงจากการประเมิน"@th,
        "從評估中識別改善。"@zh ;
    skos:inScheme <https://example.org/nist-csf-2.0/scheme/core> ;
    skos:notation "ID.IM-01" ;
    skos:prefLabel "Verbesserungen werden anhand von Bewertungen ermittelt."@de,

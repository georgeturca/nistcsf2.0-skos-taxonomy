        csfref:NICE-Framework-IO-WRL-001,
        csfref:NICE-Framework-IO-WRL-003,
        csfref:NICE-Framework-IO-WRL-006,
        csfref:NICE-Framework-OG-WRL-012,
        csfref:NICE-Framework-PD-WRL-002,
        csfref:NICE-Framework-PD-WRL-003,
        csfref:NICE-Framework-PD-WRL-004,
        csfref:OWASP-Top-10-LLM-Applications-LLM01-2025,
        csfref:OWASP-Top-10-LLM-Applications-LLM04-2025,
        csfref:OWASP-Top-10-LLM-Applications-LLM05-2025,
        csfref:PCI-DSS-10-2-1,
        csfref:PCI-DSS-10-2-2,

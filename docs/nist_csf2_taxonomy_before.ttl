csf:PR-AA-04 a skos:Concept ;
    dcterms:type "Subcategory" ;
    skos:broader csf:PR-AA ;
    skos:definition "Identitätsbestätigungen werden geschützt, übermittelt und überprüft."@de,
        "Οι ισχυρισμοί ταυτότητας προστατεύονται, διαβιβάζονται και επαληθεύονται"@el,
        "Identity assertions are protected, conveyed, and verified"@en,
        "Las afirmaciones de identidad se protegen, transmiten y verifican"@es,
        "Les affirmations d’identité sont protégées, transmises et vérifiées"@fr,
        "ID アサーションが保護され、伝達され、検証されている。"@ja,
        "신원 확인 내용은 보호되고, 전달되며, 검증됩니다."@ko,
        "Identitetserklæringer beskyttes, formidles og verifiseres"@no,
        "potwierdzenia tożsamości są chronione, przekazywane i weryfikowane."@pl,
        "As afirmações de identidade são protegidas, transmitidas e verificadas"@pt,
        "การยืนยนั ตวั ตนไดร้ ับการจดั ทา ขึ้น มีการปกป้องและตรวจสอบความปลอดภยั"@th,
        "身分判定受到保護、傳遞及驗證。"@zh ;
    skos:inScheme <https://example.org/nist-csf-2.0/scheme/core> ;
    skos:notation "PR.AA-04" ;
    skos:prefLabel "Identitätsbestätigungen werden geschützt, übermittelt und überprüft."@de,
        "Οι ισχυρισμοί ταυτότητας προστατεύονται, διαβιβάζονται και επαληθεύονται"@el,
        "Identity assertions are protected, conveyed, and verified"@en,
        "Las afirmaciones de identidad se protegen, transmiten y verifican"@es,
        "Les affirmations d’identité sont protégées, transmises et vérifiées"@fr,
        "ID アサーションが保護され、伝達され、検証されている。"@ja,
        "신원 확인 내용은 보호되고, 전달되며, 검증됩니다."@ko,
        "Identitetserklæringer beskyttes, formidles og verifiseres"@no,
        "potwierdzenia tożsamości są chronione, przekazywane i weryfikowane."@pl,
        "As afirmações de identidade são protegidas, transmitidas e verificadas"@pt,
        "การยืนยนั ตวั ตนไดร้ ับการจดั ทา ขึ้น มีการปกป้องและตรวจสอบความปลอดภยั"@th,
        "身分判定受到保護、傳遞及驗證。"@zh ;
    csfprop:hasInformativeReference csfref:CCMv4-0-IAM-01,
        csfref:CCMv4-0-IAM-03,
        csfref:CCMv4-0-IAM-16,
        csfref:CRI-Profile-v2-0-PR-AA-04,

csf:ID a skos:Concept ;
    dcterms:type "Function" ;
    skos:definition "Die aktuellen Cybersicherheitsrisiken der Organisation sind bekannt."@de,
        "Γίνονται κατανοητοί οι τρέχοντες κίνδυνοι κυβερνοασφάλειας του οργανισμού"@el,
        "The organization's current cybersecurity risks are understood"@en,
        "Se conocen los riesgos de seguridad cibernética actuales de la organización"@es,
        "Les risques actuels de cybersécurité de l’organisation sont compris"@fr,
        "組織の現在のサイバーセキュリティリスクが理解されている。"@ja,
        "조직의 현재 사이버보안 위험을 이해합니다."@ko,
        "Organisasjonens nåværende cybersikkerhetsrisiko er forstått"@no,
        "bieżące zagrożenia organizacji w zakresie cyberbezpieczeństwa organizacji są zrozumiałe."@pl,
        "Os riscos atuais de segurança cibernética da organização são compreendidos"@pt,
        "เขา้ ใจความเสี่ยงดา้ นการรักษาความปลอดภยั ทางไซเบอร์ในปัจจุบนั ขององค์กร"@th,
        "理解組織目前的網路安全風險"@zh ;
    skos:inScheme <https://example.org/nist-csf-2.0/scheme/core> ;
    skos:narrower csf:ID-AM,
        csf:ID-IM,
        csf:ID-RA ;
    skos:notation "ID" ;
    skos:prefLabel "IDENTIFIZIEREN"@de,
        "ΠΡΟΣΔΙΟΡΙΣΜΟΣ"@el,
        "IDENTIFY"@en,
        "IDENTIFICAR"@es,
        "IDENTIFIER"@fr,
        "識別"@ja,
        "IDENTIFY"@ko,
        "IDENTIFISERE"@no,
        "IDENTYFIKACJA"@pl,
        "IDENTIFICAR"@pt,
        "ระบุ"@th,
        "識別"@zh ;
    skos:topConceptOf <https://example.org/nist-csf-2.0/scheme/core> ;
    csfprop:hasInformativeReference csfref:CRI-Profile-v2-0-ID,
        csfref:CSF-v1-1-ID,
        csfref:ISO-IEC-27001-2022-Annex-A-Controls-None,
        csfref:ISO-IEC-27001-2022-Mandatory-Clause-10-2,
        csfref:ISO-IEC-27001-2022-Mandatory-Clause-8-1,
        csfref:ISO-IEC-27001-2022-Mandatory-Clause-8-2,
        csfref:ISO-IEC-27001-2022-Mandatory-Clause-8-3,
        csfref:SCF-RSK-01,
        csfref:SCF-RSK-01-1,
        csfref:SCF-RSK-04,
        csfref:SCF-RSK-09 ;
    csfprop:informativeReferenceText """CRI Profile v2.0: ID
CSF v1.1: ID

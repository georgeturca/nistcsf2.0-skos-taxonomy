        csfref:SP-800-221A-GV-CT-5,
        csfref:SP-800-37-Rev-2-RMF-Prepare-Step-Organization-Mission-Business-Levels-TASK-P-2-Risk-Management-Strategy,
        csfref:SP-800-37-Rev-2-RMF-Prepare-Step-Organization-Mission-Business-Levels-TASK-P-3-Risk-Assessment-Organization,
        csfref:SP-800-37-Rev-2-RMF-Prepare-Step-System-Level-TASK-P-14-Risk-Assessment-System,
        csfref:SP-800-37-Rev-2-RMF-Prepare-Step-System-Level-TASK-P-15-Requirements-Definition,
        csfref:SP-800-37-Rev-2-RMF-Prepare-Step-System-Level-TASK-P-8-Mission-or-Business-Focus,
        csfref:SP-800-37-Rev-2-RMF-Prepare-Step-System-Level-TASK-P-9-System-Stakeholders ;
    csfprop:informativeReferenceText """CRI Profile v2.0: GV.OC
CSF v1.1: ID.BE
ISO/IEC 27001:2022: Mandatory Clause: 4.2(a)
